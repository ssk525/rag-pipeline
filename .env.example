# Google Gemini API (for embeddings; optional for generation if using Ollama)
GOOGLE_API_KEY=your_gemini_api_key_here

# Local Ollama (free, runs on your Mac — set USE_OLLAMA=1 to generate answers locally)
USE_OLLAMA=1
OLLAMA_MODEL=gemma4:e4b

# Optional: Cohere API for Reranker (Free tier: https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=your_cohere_api_key_here

# Flask API port (default 5000)
API_PORT=5000
